let deals = JSON.parse(localStorage.getItem('deals_v2') || '[]');
const SMAP = {new:'s-new',follow:'s-follow',neg:'s-neg',closed:'s-closed',lost:'s-lost'};
const SLABEL = {new:'New Lead',follow:'Follow-up',neg:'Negotiating',closed:'Closed ✓',lost:'Lost'};

function addDeal() {
  const buyer = document.getElementById('p-buyer').value.trim();
  if (!buyer) { alert('Enter buyer name'); return; }
  deals.unshift({
    id:Date.now(),
    date:new Date().toLocaleDateString('en-IN'),
    buyer,
    city:document.getElementById('p-city').value,
    comm:document.getElementById('p-comm').value,
    qty:document.getElementById('p-qty').value,
    status:document.getElementById('p-status').value,
    src:document.getElementById('p-src').value,
    note:''
  });
  localStorage.setItem('deals_v2', JSON.stringify(deals));
  ['p-buyer','p-city','p-qty'].forEach(id=>document.getElementById(id).value='');
  renderPipeline();
  updateKPIs();
}

function updateDealStatus(id, val) {
  deals = deals.map(d => d.id===id ? {...d, status:val} : d);
  localStorage.setItem('deals_v2', JSON.stringify(deals));
  updateKPIs();
}

function deleteDeal(id) {
  if (!confirm('Delete this deal?')) return;
  deals = deals.filter(d => d.id!==id);
  localStorage.setItem('deals_v2', JSON.stringify(deals));
  renderPipeline();
  updateKPIs();
}

function renderPipeline() {
  if (!deals.length) {
    document.getElementById('pipe-tbody').innerHTML = '<tr><td colspan="10" style="text-align:center;color:var(--muted);padding:2rem;font-size:.68rem">No deals yet. Add your first lead above.</td></tr>';
    return;
  }
  document.getElementById('pipe-tbody').innerHTML = deals.map((d,i) => `
    <tr>
      <td style="color:var(--muted)">${deals.length-i}</td>
      <td style="color:var(--muted);font-size:.58rem">${d.date}</td>
      <td style="color:var(--cream);font-weight:500">${d.buyer}</td>
      <td style="color:var(--muted)">${d.city}</td>
      <td style="color:var(--turmeric)">${d.comm}</td>
      <td style="color:var(--muted)">${d.qty}</td>
      <td><span class="sbadge ${SMAP[d.status]}">${SLABEL[d.status]}</span></td>
      <td style="color:var(--muted);font-size:.58rem">${d.src}</td>
      <td style="color:var(--muted);font-size:.58rem;max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${d.note||'—'}</td>
      <td style="display:flex;align-items:center;gap:.3rem">
        <select onchange="updateDealStatus(${d.id},this.value)" style="background:var(--surface2);border:1px solid var(--line);color:var(--muted);font-size:.58rem;padding:2px 3px;font-family:'IBM Plex Mono',monospace">
          ${Object.keys(SMAP).map(k=>`<option value="${k}" ${d.status===k?'selected':''}>${SLABEL[k]}</option>`).join('')}
        </select>
        <button class="del-btn" onclick="deleteDeal(${d.id})">✕</button>
      </td>
    </tr>`).join('');
}

function updateKPIs() {
  const active = deals.filter(d=>!['closed','lost'].includes(d.status));
  document.getElementById('k-leads').textContent = active.length;
  document.getElementById('k-follow').textContent = deals.filter(d=>d.status==='follow').length;
  const thisMonth = deals.filter(d=>{
    if(d.status!=='closed') return false;
    const parts = d.date.split('/');
    if(parts.length===3){const m=parseInt(parts[1])-1,y=parseInt(parts[2]);return m===CM&&y===NOW.getFullYear();}
    return false;
  });
  document.getElementById('k-closed').textContent = thisMonth.length;
}

