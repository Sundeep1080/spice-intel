// ═══════════════════════════════════════════════════
//  LIVE PRICE FETCH — data.gov.in
// ═══════════════════════════════════════════════════
function setStatus(dot, text) {
  document.getElementById('sdot').className = 'status-dot ' + dot;
  document.getElementById('stext').textContent = text;
}

async function fetchAllPrices() {
  const key = getApiKey();
  if (!key) {
    document.getElementById('api-banner').classList.remove('hidden');
    setStatus('dot-red', 'No API key. Enter your data.gov.in key above.');
    return;
  }
  setStatus('dot-yellow', 'Fetching live mandi prices from data.gov.in…');
  document.getElementById('refresh-btn').disabled = true;

  const prices = getPrices();
  let fetched = 0;

  // Commodities that can be fetched from API (0,2,4,5,7,8 = Chilli,Pepper,Turmeric,Ginger,Rice,Rice)
  const fetchable = [0, 2, 4, 5, 7, 8];

  const promises = fetchable.map(async (ci) => {
    try {
      const commName = API_COMMODITY_NAMES[ci];
      const url = `https://api.data.gov.in/resource/${API_RESOURCE}?api-key=${key}&format=json&limit=10&filters[commodity]=${encodeURIComponent(commName)}`;
      const res = await fetch(url);
      if (!res.ok) throw new Error('HTTP ' + res.status);
      const data = await res.json();
      const records = data.records || [];
      if (records.length > 0) {
        // Pick most recent / most relevant record
        const r = records[0];
        if (!prices[ci]) prices[ci] = {};
        prices[ci].min_api   = r.min_price  || r.minimum_price  || '—';
        prices[ci].modal_api = r.modal_price || r.modal          || '—';
        prices[ci].max_api   = r.max_price  || r.maximum_price  || '—';
        prices[ci].mandi_api = r.market     || r.market_name    || '';
        prices[ci].date      = r.arrival_date || new Date().toLocaleDateString('en-IN');
        fetched++;
      }
    } catch(e) {
      console.warn('Price fetch failed for index', ci, e.message);
    }
  });

  await Promise.all(promises);
  savePrices(prices);
  renderPrices();
  document.getElementById('refresh-btn').disabled = false;
  document.getElementById('k-priceup').textContent = new Date().toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'});

  if (fetched > 0) {
    setStatus('dot-green', `✓ Fetched live prices for ${fetched} commodities from data.gov.in  (${new Date().toLocaleString('en-IN')})`);
  } else {
    setStatus('dot-red', 'Fetch returned no data. Check your API key or try again. Manual entry still works below.');
  }
}

// ═══════════════════════════════════════════════════
//  RENDER PRICE TABLE
// ═══════════════════════════════════════════════════
function renderPrices() {
  const prices = getPrices();
  let html = '';
  PRICE_META.forEach((m, i) => {
    const p = prices[i] || {};
    const margin = (p.buy && p.sell) ? '₹' + (parseFloat(p.sell) - parseFloat(p.buy)).toFixed(0) + '/kg' : '—';
    const tc = m.trend === '↑' ? 'var(--success)' : m.trend === '↓' ? 'var(--danger)' : 'var(--muted)';
    html += `<tr>
      <td style="color:var(--turmeric);font-weight:500">${m.comm}</td>
      <td style="color:var(--muted);font-size:.6rem">${m.origin}</td>
      <td style="color:var(--muted);font-size:.6rem">${m.grade}</td>
      <td style="color:#60a880;font-size:.65rem">${p.min_api || '—'}</td>
      <td style="color:var(--cream);font-size:.65rem;font-weight:500">${p.modal_api || '—'}</td>
      <td style="color:#a06040;font-size:.65rem">${p.max_api || '—'}</td>
      <td><input class="price-cell" value="${p.buy||''}" placeholder="₹/kg" onchange="saveManual(${i},'buy',this.value)" onkeydown="if(event.key==='Enter')this.blur()"></td>
      <td><input class="price-cell" value="${p.sell||''}" placeholder="₹/kg" onchange="saveManual(${i},'sell',this.value)" onkeydown="if(event.key==='Enter')this.blur()"></td>
      <td style="color:${margin==='—'?'var(--muted)':'var(--success)'};font-size:.65rem">${margin}</td>
      <td style="color:${tc}">${m.trend}</td>
      <td style="color:var(--muted);font-size:.58rem">${p.date||'—'}</td>
    </tr>`;
  });
  document.getElementById('price-tbody').innerHTML = html;
}

function saveManual(i, field, val) {
  const prices = getPrices();
  if (!prices[i]) prices[i] = {};
  prices[i][field] = val;
  prices[i].date = new Date().toLocaleDateString('en-IN');
  savePrices(prices);
  renderPrices();
}

