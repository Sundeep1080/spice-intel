<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>SPICE INTEL — Byadgi Trade Command</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=IBM+Plex+Mono:wght@300;400;500&family=Crimson+Pro:ital,wght@0,300;0,400;0,600;1,300&display=swap" rel="stylesheet">
<style>
:root {
  --saffron: #E8850A;
  --turmeric: #D4A017;
  --chilli: #C0392B;
  --pepper: #1a1a2e;
  --cardamom: #2d6a4f;
  --cream: #FDF6E3;
  --ink: #1C1209;
  --muted: #8B7355;
  --border: #D4C4A0;
  --success: #27ae60;
  --danger: #e74c3c;
  --warn: #f39c12;
  --surface: #1C160E;
  --surface2: #13100a;
  --line: #2a2015;
}
* { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior:smooth; }
body {
  background:var(--ink);
  color:var(--cream);
  font-family:'IBM Plex Mono',monospace;
  min-height:100vh;
  overflow-x:hidden;
}
body::before {
  content:'';
  position:fixed;
  inset:0;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
  pointer-events:none;
  z-index:9999;
}

/* ── TOPBAR ── */
.topbar {
  background:linear-gradient(90deg,var(--chilli) 0%,#7a1508 60%,var(--ink) 100%);
  padding:0 1rem;
  display:flex;
  align-items:center;
  justify-content:space-between;
  border-bottom:2px solid var(--saffron);
  position:sticky;
  top:0;
  z-index:200;
  height:52px;
  gap:0.5rem;
}
.brand {
  font-family:'Playfair Display',serif;
  font-size:1.1rem;
  font-weight:900;
  color:var(--cream);
  white-space:nowrap;
  display:flex;
  align-items:center;
  gap:0.4rem;
}
.brand em { color:var(--turmeric); font-style:normal; }
.live-pill {
  background:var(--success);
  color:#fff;
  font-size:0.55rem;
  padding:2px 6px;
  border-radius:2px;
  letter-spacing:.1em;
  animation:blink 2s infinite;
}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.4}}
.topbar-right {
  display:flex;
  align-items:center;
  gap:0.7rem;
  font-size:0.62rem;
  color:var(--border);
  flex-shrink:0;
}
#clock { color:var(--turmeric); font-weight:500; }

/* ── API KEY BANNER ── */
#api-banner {
  background:#1a0e06;
  border-bottom:1px solid var(--saffron);
  padding:0.5rem 1rem;
  display:flex;
  align-items:center;
  gap:0.6rem;
  flex-wrap:wrap;
}
#api-banner.hidden { display:none; }
.api-label { font-size:0.62rem; color:var(--turmeric); white-space:nowrap; }
#api-key-input {
  flex:1;
  min-width:200px;
  background:#13100a;
  border:1px solid var(--saffron);
  color:var(--cream);
  font-family:'IBM Plex Mono',monospace;
  font-size:0.68rem;
  padding:0.35rem 0.6rem;
  outline:none;
  border-radius:2px;
}
.btn-api {
  background:var(--saffron);
  color:var(--ink);
  border:none;
  font-family:'IBM Plex Mono',monospace;
  font-size:0.65rem;
  font-weight:600;
  padding:0.35rem 0.9rem;
  cursor:pointer;
  border-radius:2px;
  white-space:nowrap;
}
.btn-api:hover { background:var(--turmeric); }
.api-help { font-size:0.58rem; color:var(--muted); }
.api-help a { color:var(--saffron); }

/* ── TABS ── */
.tabs {
  background:#100d07;
  border-bottom:1px solid var(--line);
  display:flex;
  overflow-x:auto;
  scrollbar-width:none;
  padding:0 0.5rem;
  position:sticky;
  top:52px;
  z-index:100;
}
.tabs::-webkit-scrollbar{display:none}
.tab {
  padding:.65rem 1.1rem;
  font-size:.62rem;
  letter-spacing:.07em;
  text-transform:uppercase;
  color:var(--muted);
  cursor:pointer;
  border-bottom:2px solid transparent;
  white-space:nowrap;
  transition:all .2s;
  font-family:'IBM Plex Mono',monospace;
  user-select:none;
}
.tab:hover{color:var(--cream)}
.tab.active{color:var(--saffron);border-bottom-color:var(--saffron)}

/* ── MAIN ── */
.main { padding:1rem; max-width:1600px; margin:0 auto; }
.panel { display:none; }
.panel.active { display:block; animation:fadeUp .3s ease; }
@keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}

/* ── CARD ── */
.card {
  background:var(--surface);
  border:1px solid var(--line);
  border-radius:3px;
  padding:1rem;
  margin-bottom:1rem;
}
.card-title {
  font-family:'Playfair Display',serif;
  font-size:0.78rem;
  color:var(--turmeric);
  letter-spacing:.04em;
  margin-bottom:.8rem;
  display:flex;
  align-items:center;
  gap:.4rem;
  text-transform:uppercase;
}
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
.grid-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:1rem}

/* ── SECTION HEADER ── */
.section-header {
  font-family:'Playfair Display',serif;
  font-size:1.05rem;
  color:var(--cream);
  margin-bottom:.2rem;
}
.section-sub {
  font-size:.62rem;
  color:var(--muted);
  margin-bottom:1rem;
  font-family:'Crimson Pro',serif;
  font-style:italic;
  line-height:1.5;
}

/* ── KPI ── */
.kpi-strip {
  display:grid;
  grid-template-columns:repeat(8,1fr);
  gap:.5rem;
  margin-bottom:1rem;
}
.kpi {
  background:var(--surface);
  border:1px solid var(--line);
  border-top:2px solid var(--saffron);
  padding:.7rem .5rem;
  text-align:center;
}
.kpi-label { font-size:.52rem; color:var(--muted); text-transform:uppercase; letter-spacing:.07em; margin-bottom:.25rem; }
.kpi-value { font-size:1rem; font-weight:500; color:var(--cream); font-family:'Playfair Display',serif; }
.kpi-sub { font-size:.55rem; margin-top:.15rem; color:var(--muted); }
.up{color:var(--success)}.down{color:var(--danger)}.neu{color:var(--muted)}

/* ── PRICE TABLE ── */
table { width:100%; border-collapse:collapse; font-size:.68rem; }
th {
  background:var(--surface2);
  color:var(--turmeric);
  padding:.5rem .7rem;
  text-align:left;
  font-size:.58rem;
  letter-spacing:.06em;
  text-transform:uppercase;
  font-weight:400;
  border-bottom:1px solid var(--line);
}
td { padding:.5rem .7rem; border-bottom:1px solid #1f1910; vertical-align:middle; }
tr:hover td { background:#221a0f; }
.price-cell {
  background:transparent;
  border:none;
  border-bottom:1px solid #3a3020;
  color:var(--turmeric);
  font-family:'IBM Plex Mono',monospace;
  font-size:.68rem;
  width:90px;
  padding:2px 4px;
  outline:none;
}
.price-cell:focus{border-bottom-color:var(--saffron)}

/* ── PRICE STATUS ── */
.fetch-status {
  display:flex;
  align-items:center;
  gap:.5rem;
  font-size:.62rem;
  margin-bottom:.8rem;
  padding:.5rem .8rem;
  background:var(--surface2);
  border-radius:2px;
  border:1px solid var(--line);
}
.status-dot { width:8px; height:8px; border-radius:50%; flex-shrink:0; }
.dot-green{background:var(--success)}
.dot-yellow{background:var(--warn);animation:blink 1.5s infinite}
.dot-red{background:var(--danger)}
.dot-gray{background:var(--muted)}

/* ── HEATMAP ── */
.heatmap-wrap { overflow-x:auto; }
.heatmap-grid {
  display:grid;
  gap:2px;
  font-size:.58rem;
  min-width:700px;
}
.hm-header {
  background:var(--surface2);
  padding:.35rem .25rem;
  text-align:center;
  color:var(--muted);
  font-size:.54rem;
}
.hm-city {
  background:var(--surface2);
  padding:.35rem .5rem;
  color:var(--cream);
  font-size:.6rem;
  display:flex;
  align-items:center;
}
.hm-cell {
  padding:.35rem .1rem;
  text-align:center;
  cursor:default;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:.6rem;
  font-weight:500;
  border-radius:2px;
  transition:transform .1s;
}
.hm-cell:hover{transform:scale(1.08);z-index:5;position:relative}
.h0{background:#1C160E;color:#3a3020}
.h1{background:#2d1f0a;color:#8B6530}
.h2{background:#4a2e08;color:#C4874A}
.h3{background:#6b3a0a;color:#E8A560}
.h4{background:#8B4A0C;color:#F0C070}
.h5{background:#C0392B;color:#FFF3CD}

/* ── SEASON ── */
.season-row{display:flex;align-items:center;margin-bottom:.4rem;gap:.3rem}
.season-label{width:120px;font-size:.6rem;color:var(--cream);flex-shrink:0;line-height:1.3}
.season-sublabel{font-size:.5rem;color:var(--muted)}
.season-months{display:flex;gap:2px;flex:1;min-width:280px}
.mcell{flex:1;height:26px;border-radius:2px;display:flex;align-items:center;justify-content:center;font-size:.48rem;font-weight:500;cursor:default;transition:opacity .15s}
.mcell:hover{opacity:.75}
.s-off{background:#1f1910;color:#3a3020}
.s-low{background:#1a3020;color:#60a870}
.s-mid{background:#7a5e10;color:#F0C060}
.s-peak{background:#8B1A10;color:#FFC8C0}
.s-harv{background:#0f3a1a;color:#80EE90}

/* ── BUYER / SUPPLIER CARDS ── */
.cards-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:.7rem}
.bcard {
  background:var(--surface);
  border:1px solid var(--line);
  padding:.85rem;
  border-radius:3px;
  position:relative;
  transition:border-color .2s;
}
.bcard:hover{border-color:var(--saffron)}
.scard {
  background:#0d1a10;
  border:1px solid #1a3020;
  padding:.85rem;
  border-radius:3px;
  transition:border-color .2s;
}
.scard:hover{border-color:var(--cardamom)}
.tier-badge {
  position:absolute;
  top:.5rem;
  right:.5rem;
  font-size:.5rem;
  padding:2px 5px;
  border-radius:2px;
  text-transform:uppercase;
  letter-spacing:.05em;
}
.t-fmcg{background:#1a3a5c;color:#60a8e0}
.t-hotel{background:#3a1a5c;color:#a060e0}
.t-mandi{background:#1a3a1a;color:#60c060}
.t-export{background:#5c3a1a;color:#e0a060}
.t-industrial{background:#3a1a1a;color:#e06060}
.bname{font-family:'Playfair Display',serif;font-size:.85rem;color:var(--cream);margin-bottom:.2rem;padding-right:4rem}
.bcity{font-size:.58rem;color:var(--muted);margin-bottom:.4rem}
.tags{display:flex;flex-wrap:wrap;gap:3px;margin-bottom:.4rem}
.stag{background:#2a1f10;border:1px solid #3a2e18;color:var(--turmeric);font-size:.52rem;padding:1px 5px;border-radius:1px}
.ctag{background:#122010;border:1px solid #1a3020;color:#80d890;font-size:.52rem;padding:1px 5px;border-radius:1px}
.bvol{font-size:.58rem;color:var(--muted);margin-bottom:.3rem}
.bvol span{color:var(--cream)}
.bnote{font-size:.58rem;color:var(--muted);line-height:1.4;margin-bottom:.3rem}
.bcontact{font-size:.56rem;color:#60a880;margin-bottom:.5rem}
.row-btns{display:flex;gap:.35rem;margin-top:.5rem}
.btn-xs{font-family:'IBM Plex Mono',monospace;font-size:.55rem;padding:3px 9px;border:1px solid;background:transparent;cursor:pointer;border-radius:2px;letter-spacing:.04em;transition:all .15s}
.btn-green{border-color:var(--success);color:var(--success)}
.btn-green:hover{background:var(--success);color:#fff}
.btn-gray{border-color:var(--muted);color:var(--muted)}
.btn-gray:hover{background:var(--muted);color:var(--ink)}

/* ── PIPELINE ── */
.pipe-form{display:grid;grid-template-columns:repeat(3,1fr) repeat(3,1fr) auto;gap:.5rem;align-items:end;margin-bottom:.8rem}
.fg{display:flex;flex-direction:column;gap:.25rem}
.flabel{font-size:.55rem;color:var(--muted);text-transform:uppercase;letter-spacing:.06em}
.finput,.fselect{background:var(--surface2);border:1px solid var(--line);color:var(--cream);font-family:'IBM Plex Mono',monospace;font-size:.65rem;padding:.35rem .5rem;outline:none;border-radius:2px;transition:border-color .15s;width:100%}
.finput:focus,.fselect:focus{border-color:var(--saffron)}
.fselect option{background:var(--surface)}
.btn-add{background:var(--saffron);color:var(--ink);border:none;font-family:'IBM Plex Mono',monospace;font-size:.65rem;font-weight:600;padding:.38rem .9rem;cursor:pointer;border-radius:2px;letter-spacing:.04em;white-space:nowrap}
.btn-add:hover{background:var(--turmeric)}
.sbadge{font-size:.55rem;padding:2px 7px;border-radius:2px;text-transform:uppercase;letter-spacing:.04em}
.s-new{background:#1a3a5c;color:#60a8e0}
.s-follow{background:#3a2a0a;color:var(--turmeric)}
.s-neg{background:#1a2a3a;color:#60c0e0}
.s-closed{background:#1a3a1a;color:var(--success)}
.s-lost{background:#2a1a1a;color:#e06060}
.del-btn{background:none;border:none;color:#5a3030;cursor:pointer;font-size:.8rem;transition:color .15s}
.del-btn:hover{color:var(--danger)}

/* ── INTEL ITEMS ── */
.intel-item{border-left:3px solid;padding:.65rem .9rem;margin-bottom:.5rem;background:#161009}
.intel-item.hi{border-color:var(--chilli)}
.intel-item.med{border-color:var(--saffron)}
.intel-item.lo{border-color:var(--cardamom)}
.intel-hd{display:flex;justify-content:space-between;align-items:center;margin-bottom:.2rem}
.itag{font-size:.52rem;text-transform:uppercase;letter-spacing:.07em;font-weight:500}
.intel-item.hi .itag{color:var(--chilli)}
.intel-item.med .itag{color:var(--saffron)}
.intel-item.lo .itag{color:#60a880}
.itime{font-size:.55rem;color:var(--muted)}
.ititle{font-size:.75rem;color:var(--cream);margin-bottom:.2rem;font-family:'Crimson Pro',serif;font-weight:600}
.ibody{font-size:.62rem;color:var(--muted);line-height:1.5}

/* ── SOURCE LINKS ── */
.source-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:.6rem;margin-bottom:1rem}
.slink{background:var(--surface2);border:1px solid var(--line);padding:.7rem;border-radius:3px;text-decoration:none;display:block;transition:border-color .2s}
.slink:hover{border-color:var(--saffron)}
.slink-title{font-size:.68rem;color:var(--cream);margin-bottom:.15rem}
.slink-desc{font-size:.58rem;color:var(--muted);line-height:1.4}
.slink-url{font-size:.55rem;color:var(--saffron);margin-top:.25rem}

/* ── MODAL ── */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.82);z-index:500;align-items:center;justify-content:center}
.modal-overlay.open{display:flex}
.modal{background:var(--surface);border:1px solid var(--saffron);padding:1.3rem;max-width:480px;width:92%;border-radius:4px}
.modal-title{font-family:'Playfair Display',serif;font-size:1rem;color:var(--turmeric);margin-bottom:.8rem}
.modal-close{float:right;background:none;border:none;color:var(--muted);cursor:pointer;font-size:1.2rem;margin-top:-.2rem}
.modal textarea{width:100%;background:var(--surface2);border:1px solid var(--line);color:var(--cream);font-family:'IBM Plex Mono',monospace;font-size:.65rem;padding:.5rem;min-height:90px;resize:vertical;outline:none;border-radius:2px;margin-top:.4rem}

/* ── SEARCH / FILTER BAR ── */
.sbar{display:flex;gap:.4rem;margin-bottom:.8rem;flex-wrap:wrap;align-items:center}
.sinput{flex:1;min-width:160px;background:var(--surface2);border:1px solid var(--line);color:var(--cream);font-family:'IBM Plex Mono',monospace;font-size:.65rem;padding:.4rem .7rem;outline:none;border-radius:2px}
.sinput:focus{border-color:var(--saffron)}
.fbtn{background:var(--surface2);border:1px solid var(--line);color:var(--muted);font-family:'IBM Plex Mono',monospace;font-size:.58rem;padding:.4rem .7rem;cursor:pointer;border-radius:2px;text-transform:uppercase;letter-spacing:.04em;transition:all .15s;white-space:nowrap}
.fbtn.on,.fbtn:hover{border-color:var(--saffron);color:var(--saffron)}

/* ── LEGEND ── */
.legend{display:flex;gap:.8rem;flex-wrap:wrap;margin-bottom:.7rem}
.litem{display:flex;align-items:center;gap:.25rem;font-size:.58rem;color:var(--muted)}
.ldot{width:10px;height:10px;border-radius:1px}

/* ── CHECKLIST ── */
.check-row{display:flex;gap:.5rem;margin-bottom:.45rem;align-items:flex-start}
.check-time{color:var(--saffron);font-size:.58rem;min-width:50px;margin-top:.05rem}
.check-text{font-size:.62rem;color:var(--cream);line-height:1.4}

/* ── SCROLLBAR ── */
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-track{background:var(--surface2)}
::-webkit-scrollbar-thumb{background:#3a2e18;border-radius:2px}

/* ── RESPONSIVE ── */
@media(max-width:900px){
  .kpi-strip{grid-template-columns:repeat(4,1fr)}
  .cards-grid{grid-template-columns:1fr 1fr}
  .grid-2,.grid-3{grid-template-columns:1fr}
  .source-grid{grid-template-columns:1fr 1fr}
  .pipe-form{grid-template-columns:1fr 1fr}
}
@media(max-width:600px){
  .kpi-strip{grid-template-columns:repeat(2,1fr)}
  .cards-grid{grid-template-columns:1fr}
  .source-grid{grid-template-columns:1fr}
  .pipe-form{grid-template-columns:1fr}
  .brand{font-size:.9rem}
  .topbar-right{font-size:.55rem;gap:.4rem}
}
</style>
</head>
<body>

<!-- TOPBAR -->
<div class="topbar">
  <div class="brand">🌶 SPICE <em>INTEL</em></div>
  <div class="topbar-right">
    <span class="live-pill">● LIVE</span>
    <span id="clock"></span>
    <span style="color:#3a3020">|</span>
    <span>Byadgi, Karnataka</span>
  </div>
</div>

<!-- API KEY BANNER -->
<div id="api-banner">
  <span class="api-label">🔑 data.gov.in API Key:</span>
  <input id="api-key-input" type="text" placeholder="Paste your free API key here (register at data.gov.in)">
  <button class="btn-api" onclick="saveApiKey()">Save &amp; Fetch Prices</button>
  <span class="api-help">
    Get free key: <a href="https://data.gov.in/user/register" target="_blank">data.gov.in/user/register</a>
    → Login → My Account → API Keys → Generate
  </span>
</div>

<!-- TABS -->
<div class="tabs">
  <div class="tab active" onclick="switchTab('overview',this)">⬡ Overview</div>
  <div class="tab" onclick="switchTab('prices',this)">₹ Live Prices</div>
  <div class="tab" onclick="switchTab('demand',this)">◉ Demand Radar</div>
  <div class="tab" onclick="switchTab('seasons',this)">◈ Seasons</div>
  <div class="tab" onclick="switchTab('buyers',this)">▣ Buyers</div>
  <div class="tab" onclick="switchTab('suppliers',this)">◆ Suppliers</div>
  <div class="tab" onclick="switchTab('pipeline',this)">⟳ Pipeline</div>
  <div class="tab" onclick="switchTab('intel',this)">◎ Daily Intel</div>
</div>

<div class="main">

<!-- ══════════════════ OVERVIEW ══════════════════ -->
<div class="panel active" id="panel-overview">
  <div class="section-header">🌶 Morning Command — <span id="today-date" style="color:var(--saffron)"></span></div>
  <div class="section-sub">Asset-light spice brokerage · Byadgi Chilli · Black &amp; White Pepper · Turmeric · Dry Ginger · Cashews · Rice · Karnataka origin</div>

  <div class="kpi-strip">
    <div class="kpi"><div class="kpi-label">Active Leads</div><div class="kpi-value" id="k-leads">0</div><div class="kpi-sub neu">pipeline</div></div>
    <div class="kpi"><div class="kpi-label">Follow-ups</div><div class="kpi-value" id="k-follow">0</div><div class="kpi-sub down">today</div></div>
    <div class="kpi"><div class="kpi-label">Closed</div><div class="kpi-value" id="k-closed">0</div><div class="kpi-sub up">this month</div></div>
    <div class="kpi"><div class="kpi-label">Buyers DB</div><div class="kpi-value">54</div><div class="kpi-sub neu">verified</div></div>
    <div class="kpi"><div class="kpi-label">Suppliers</div><div class="kpi-value">22</div><div class="kpi-sub neu">networked</div></div>
