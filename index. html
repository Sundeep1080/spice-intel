const DL = ['—','Low','Mod','Good','High','🔥'];

function renderHeatmap(containerId, cols) {
  const numComms = cols || 9;
  const shortLabels = CSHORT.slice(0, numComms);
  let html = `<div class="hm-header" style="text-align:left;padding-left:.5rem">City↓ / Spice→</div>`;
  shortLabels.forEach(s => { html += `<div class="hm-header">${s}</div>`; });

  CITIES.forEach((city, ci) => {
    html += `<div class="hm-city">${city}</div>`;
    for (let oi = 0; oi < numComms; oi++) {
      const d = getDemand(oi, ci);
      html += `<div class="hm-cell h${d}" title="${COMMS[oi]} in ${city}: ${DL[d]}">${DL[d]}</div>`;
    }
  });

  const el = document.getElementById(containerId);
  el.style.gridTemplateColumns = `110px repeat(${numComms},1fr)`;
  el.innerHTML = html;
}

