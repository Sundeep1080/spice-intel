let modalTarget = '';
function openModal(name) {
  modalTarget = name;
  document.getElementById('modal-ctx').textContent = 'Note for: ' + name;
  const notes = JSON.parse(localStorage.getItem('notes_v2')||'{}');
  document.getElementById('modal-note').value = notes[name]||'';
  document.getElementById('noteModal').classList.add('open');
}
function closeModal() { document.getElementById('noteModal').classList.remove('open'); }
function saveNote() {
  const notes = JSON.parse(localStorage.getItem('notes_v2')||'{}');
  notes[modalTarget] = document.getElementById('modal-note').value;
  localStorage.setItem('notes_v2', JSON.stringify(notes));
  closeModal();
}
function markCalled(name) {
  const notes = JSON.parse(localStorage.getItem('notes_v2')||'{}');
  const ts = new Date().toLocaleString('en-IN');
  notes[name] = (notes[name]?notes[name]+'\n':'') + '✓ Called on ' + ts;
  localStorage.setItem('notes_v2', JSON.stringify(notes));
  alert('Logged: Called ' + name);
}

